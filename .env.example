# ============================================================================
# ALERT NOTIFICATION CONFIGURATION
# ============================================================================

# EMAIL CONFIGURATION (Using SMTP - Gmail, Outlook, etc.)
# ============================================================================
# Gmail Setup:
# 1. Enable 2-Factor Authentication: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password below

ALERT_EMAIL_RECIPIENT=ops-team@example.com
ALERT_EMAIL_SENDER=noreply@medicalrefrig.com
ALERT_SMTP_SERVER=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=your-email@gmail.com
ALERT_SMTP_PASSWORD=your-app-password-16-chars

# For Outlook/Office365:
# ALERT_SMTP_SERVER=smtp.office365.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USERNAME=your-email@outlook.com
# ALERT_SMTP_PASSWORD=your-password

# ============================================================================
# SMS CONFIGURATION (Using Twilio)
# ============================================================================
# Twilio Setup:
# 1. Create free account: https://www.twilio.com/try-twilio
# 2. Get credentials from Console: https://console.twilio.com
# 3. Buy a phone number (can start with trial for testing)
# 4. Fill in the values below

ALERT_SMS_RECIPIENT=+1234567890
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# WHATSAPP CONFIGURATION (Using Twilio)
# ============================================================================
# Uses same Twilio credentials as SMS
# WhatsApp must be enabled on your Twilio account
# Recipient must have WhatsApp installed and be part of your approved contacts

ALERT_WHATSAPP_RECIPIENT=+1234567890

# ============================================================================
# MICROSOFT TEAMS CONFIGURATION
# ============================================================================
# Teams Webhook Setup:
# 1. Go to your Teams channel
# 2. Click "..." (More options) → Connectors → Configure
# 3. Search for "Incoming Webhook"
# 4. Click "Add" or "Configure"
# 5. Give it a name and optionally upload an image
# 6. Copy the webhook URL below

ALERT_TEAMS_WEBHOOK=https://outlook.webhook.office.com/webhookb2/xxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# SLACK CONFIGURATION
# ============================================================================
# Slack Webhook Setup:
# 1. Go to https://api.slack.com/apps
# 2. Create New App → From scratch
# 3. Enable Incoming Webhooks
# 4. Add New Webhook to Workspace
# 5. Select channel and authorize
# 6. Copy the webhook URL below

ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# ============================================================================
# OTHER SETTINGS
# ============================================================================
ALERT_NOTIFICATION_LOG=alert_notifications.log

# ============================================================================
# OPTIONAL: OpenAI API for AI Compliance Assistant
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# MEDICAL REFRIGERATOR MONITOR API
# ============================================================================
MEDICAL_MONITOR_API_URL=http://127.0.0.1:8000
